<?xml version="1.0" encoding="utf-8"?>
<!-- THE 3D EXPERIMENT: map WONDER_NALANDA onto the Brihadeeswarar Temple's
     cooked model (the base game's own Chola-era Indian temple wonder — the
     closest shipped silhouette to a great mahavihara complex). Row shape from
     base-standard/data/visual-remaps.xml (REMAP_PALACE_FOUNDER). Kind values
     observed in the entire game: UNIT, BUILDING, ART_BIN — no WONDER kind
     exists, so we test whether Kind=BUILDING resolves wonder-class
     constructibles. If Nalanda renders as Brihadeeswarar's model: wonders are
     OPEN to this mod (and Konark + the Ascendant layer follow). If it renders
     blank/placeholder: record the dead end and keep the wonder data anyway
     (yields/slot still function; only the 3D visual is at stake). -->
<Database>
	<VisualRemaps>
		<Row>
			<ID>REMAP_WONDER_NALANDA</ID>
			<DisplayName>LOC_REMAP_WONDER_NALANDA</DisplayName>
			<Kind>BUILDING</Kind>
			<From>WONDER_NALANDA</From>
			<To>WONDER_BRIHADEESWARAR_TEMPLE</To>
		</Row>
	</VisualRemaps>
</Database>
