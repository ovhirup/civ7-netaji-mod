<?xml version="1.0" encoding="utf-8"?>
<!-- Leader ability: "Azad Hind Fauj"
     Design intent (see DESIGN.md):
       1. +5 Combat Strength for units fighting in friendly territory (homeland defense / liberation).
       2. No unhappiness penalty in captured settlements (liberated peoples rally to you).
       3. Burst of Culture on capturing a settlement founded by another player.

     Only effect 1 is sketched below. ModifierType strings are the part of the
     schema that MUST be validated against the game's own data — open
     <install>/Base/modules/base-standard/data/ and search existing leader
     traits for real ModifierType names, then replace the TODO values. -->
<Database>
	<Types>
		<Row Type="TRAIT_LEADER_AZAD_HIND_FAUJ" Kind="KIND_TRAIT"/>
	</Types>

	<Traits>
		<Row TraitType="TRAIT_LEADER_AZAD_HIND_FAUJ"
		     Name="LOC_TRAIT_LEADER_AZAD_HIND_FAUJ_NAME"
		     Description="LOC_TRAIT_LEADER_AZAD_HIND_FAUJ_DESCRIPTION"/>
	</Traits>

	<Modifiers>
		<!-- TODO: replace ModifierType with a real one from base-standard,
		     e.g. an "adjust unit combat strength in friendly territory" effect.
		     SubjectRequirementSetId gates the bonus to friendly-territory combat. -->
		<Row ModifierId="MOD_BOSE_HOMELAND_COMBAT_STRENGTH"
		     ModifierType="TODO_MODIFIER_PLAYER_UNITS_ADJUST_COMBAT_STRENGTH"
		     SubjectRequirementSetId="TODO_REQSET_UNIT_IN_FRIENDLY_TERRITORY"/>
	</Modifiers>

	<ModifierArguments>
		<Row ModifierId="MOD_BOSE_HOMELAND_COMBAT_STRENGTH" Name="Amount" Value="5"/>
	</ModifierArguments>

	<TraitModifiers>
		<Row TraitType="TRAIT_LEADER_AZAD_HIND_FAUJ" ModifierId="MOD_BOSE_HOMELAND_COMBAT_STRENGTH"/>
	</TraitModifiers>
</Database>
