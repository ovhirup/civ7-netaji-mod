		<Row Type="UNIT_AZAD_HIND_NAU_SENA" Kind="KIND_UNIT"/>
		<Row Type="UNIT_BAHADUR_GROUP" Kind="KIND_UNIT"/>
		<Row Type="ABILITY_RANI_OF_JHANSI_REGIMENT" Kind="KIND_ABILITY"/>
