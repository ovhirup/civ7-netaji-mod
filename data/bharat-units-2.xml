		<Row UnitType="UNIT_AZAD_HIND_NAU_SENA" Name="LOC_UNIT_AZAD_HIND_NAU_SENA_NAME" Description="LOC_UNIT_AZAD_HIND_NAU_SENA_DESCRIPTION" Tier="3" Maintenance="12" BaseMoves="4" BaseSightRange="3" ZoneOfControl="true" Domain="DOMAIN_SEA" UnitMovementClass="UNIT_MOVEMENT_CLASS_NAVAL" CoreClass="CORE_CLASS_MILITARY" FormationClass="FORMATION_CLASS_NAVAL" TraitType="TRAIT_BHARAT"/>
		<Row UnitType="UNIT_BAHADUR_GROUP" Name="LOC_UNIT_BAHADUR_GROUP_NAME" Description="LOC_UNIT_BAHADUR_GROUP_DESCRIPTION" Tier="1" Maintenance="3" BaseMoves="3" BaseSightRange="3" ZoneOfControl="false" Domain="DOMAIN_LAND" UnitMovementClass="UNIT_MOVEMENT_CLASS_FOOT" CoreClass="CORE_CLASS_MILITARY" FormationClass="FORMATION_CLASS_LAND_COMBAT" TraitType="TRAIT_BHARAT"/>
	</Units>
