<?xml version="1.0" encoding="utf-8"?>
<GameEffects xmlns="GameEffects">

	<!-- Memento A: Springing Tiger (INA insignia). +1 Combat Strength for
	     units while their owner is at war. Amount 1 matches the official
	     minor-memento band (Amina's Takoba gives +1 with a biome condition;
	     an at-war gate is broader, so it gets no more than +1).
	     Collection/effect pattern copied verbatim from base-standard's
	     MEMENTO_AMINA_TAKOBA_MODIFIER (data/mementos-gameeffects.xml):
	     collection="COLLECTION_PLAYER_COMBAT" effect=
	     "EFFECT_ADJUST_UNIT_STRENGTH_MODIFIER" with a single Requirement in
	     SubjectRequirements and an Amount Argument — mementos attach modifiers
	     directly via the MementoModifiers table, so (unlike our leader-ability
	     TraitModifiers, which need an EFFECT_ATTACH_MODIFIERS indirection onto
	     COLLECTION_UNIT_COMBAT) no attach wrapper is needed here.
	     At-war gate copied verbatim from base-standard's
	     TRUNG_TRAC_MOD_TROPICAL_SCIENCE_AT_WAR (data/leaders-gameeffects.xml,
	     ~line 773) — the only Modifier-context usage of
	     REQUIREMENT_PLAYER_HAS_X_WARS found anywhere in base-standard or the
	     DLCs (all other hits are one-off REQUIREMENT_PLAYER_DECLARED_WAR/
	     narrative-story requirements, a different "an event just happened"
	     semantic, not "is currently at war"). That official example places
	     REQUIREMENT_PLAYER_HAS_X_WARS in SubjectRequirements (not
	     OwnerRequirements) even though it is a player-level check, so we
	     mirror that placement exactly. WarType="FORMAL_WAR" Amount="1" reads
	     as "the player has at least one active formal war" — a standing
	     state check (continuously re-evaluated, no explicit WhileMet flag
	     needed, unlike the one-shot REQUIREMENT_PLAYER_DECLARED_WAR seen in
	     MEMENTO_TRUNG_DONG_SON_DRUM_MODIFIER, which does need WhileMet="true"
	     to persist). -->
	<Modifier id="MEMENTO_BOSE_SPRINGING_TIGER_MODIFIER" collection="COLLECTION_PLAYER_COMBAT" effect="EFFECT_ADJUST_UNIT_STRENGTH_MODIFIER">
		<SubjectRequirements>
			<Requirement type="REQUIREMENT_PLAYER_HAS_X_WARS">
				<Argument name="WarType">FORMAL_WAR</Argument>
				<Argument name="Amount">1</Argument>
			</Requirement>
		</SubjectRequirements>
		<Argument name="Amount">1</Argument>
		<String context="Preview">LOC_MEMENTO_BOSE_SPRINGING_TIGER_COMBAT_PREVIEW</String>
	</Modifier>

	<!-- Memento B: Azad Hind Radio (Bose's broadcasts for the independence
	     movement). +1 Influence (YIELD_DIPLOMACY) per turn, increasing each
	     Age. Amount 1 matches the official memento with this identical
	     effect (Toyotomi's Kabuto, cited below, is also Amount 1).
	     Effect structure copied verbatim from base-standard's
	     MACHIAVELLI_MOD_INFLUENCE (data/leaders-gameeffects.xml, ~line 627):
	     collection="COLLECTION_OWNER" effect="EFFECT_PLAYER_ADJUST_YIELD",
	     YieldType YIELD_DIPLOMACY, Amount type="ScaleByGameAge" extra="100".
	     The String context="Description" (pointing at FunctionalDescription,
	     instead of MACHIAVELLI's Tooltip-argument-to-ability-name) is copied
	     from the closer memento-specific precedent
	     MEMENTO_TOYOTOMI_HIDEYOSHI_KABUTO_MODIFIER (DLC/toyotomi-hideyoshi/
	     modules/data/mementos-gameeffects.xml) — an existing memento that is
	     *also* collection="COLLECTION_OWNER" effect="EFFECT_PLAYER_ADJUST_YIELD"
	     + YIELD_DIPLOMACY + ScaleByGameAge extra="100", i.e. the memento-side
	     twin of MACHIAVELLI_MOD_INFLUENCE. -->
	<Modifier id="MEMENTO_BOSE_AZAD_HIND_RADIO_MODIFIER" collection="COLLECTION_OWNER" effect="EFFECT_PLAYER_ADJUST_YIELD">
		<Argument name="YieldType">YIELD_DIPLOMACY</Argument>
		<Argument name="Amount" type="ScaleByGameAge" extra="100">1</Argument>
		<String context="Description">LOC_MEMENTO_BOSE_AZAD_HIND_RADIO_FUNCTIONAL_DESCRIPTION</String>
	</Modifier>

</GameEffects>
