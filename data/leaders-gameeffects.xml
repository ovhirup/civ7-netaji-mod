<?xml version="1.0" encoding="utf-8"?>
<!-- Leader ability "Azad Hind Fauj" + agenda "Purna Swaraj".
     All effect/requirement/collection names verified against base-standard
     and the ashoka-himiko-alt DLC in the local game install. -->
<GameEffects xmlns="GameEffects">

	<!-- 1. +5 Combat Strength for units fighting in friendly territory
	        (homeland defense / liberation). Attach pattern copied from
	        ASHOKA_ALT_MOD_CONQUEROR_ABILITY. -->
	<Modifier id="BOSE_MOD_UNIT_ATTACH_HOMELAND_STRENGTH" collection="COLLECTION_PLAYER_UNITS" effect="EFFECT_ATTACH_MODIFIERS">
		<Argument name="ModifierId">BOSE_MOD_HOMELAND_COMBAT_STRENGTH</Argument>
	</Modifier>
	<Modifier id="BOSE_MOD_HOMELAND_COMBAT_STRENGTH" collection="COLLECTION_UNIT_COMBAT" effect="EFFECT_ADJUST_UNIT_STRENGTH_MODIFIER">
		<SubjectRequirements>
			<Requirement type="REQUIREMENT_UNIT_IN_OWNER_TERRITORY"/>
		</SubjectRequirements>
		<Argument name="Amount">5</Argument>
		<String context="Preview">LOC_ABILITY_BOSE_HOMELAND_COMBAT_PREVIEW</String>
	</Modifier>

	<!-- 2. +5 Happiness in settlements you did not found (liberated peoples
	        rally to the cause). Requirement pattern copied from
	        ASHOKA_ALT_MOD_CAPTURED_SETTLEMENT_PRODUCTION. -->
	<Modifier id="BOSE_MOD_CAPTURED_SETTLEMENT_HAPPINESS" collection="COLLECTION_PLAYER_CITIES" effect="EFFECT_CITY_ADJUST_YIELD">
		<SubjectRequirements>
			<Requirement type="REQUIREMENT_CITY_IS_ORIGINAL_OWNER" inverse="true"/>
		</SubjectRequirements>
		<Argument name="YieldType">YIELD_HAPPINESS</Argument>
		<Argument name="Amount">5</Argument>
		<Argument name="Tooltip">LOC_TRAIT_LEADER_BOSE_ABILITY_NAME</Argument>
	</Modifier>

	<!-- 3. +2 Culture per conquered settlement (the liberation cause spreads). -->
	<Modifier id="BOSE_MOD_CULTURE_PER_CONQUERED_SETTLEMENT" collection="COLLECTION_OWNER" effect="EFFECT_PLAYER_ADJUST_YIELD_PER_CONQUERED_SETTLEMENT">
		<Argument name="YieldType">YIELD_CULTURE</Argument>
		<Argument name="Amount">2</Argument>
		<Argument name="Tooltip">LOC_TRAIT_LEADER_BOSE_ABILITY_NAME</Argument>
	</Modifier>

	<!-- 4. +1 Combat Strength while at war (the INA "Springing Tiger" spirit).
	        Refolded from the former Springing Tiger memento (mementos dropped —
	        custom mementos can't be made equippable without fragile core-UI-file
	        replacement). Uses the same attach->unit_combat pattern as the
	        homeland bonus above (and Ashoka's Conqueror ability): the "player is
	        at war" gate is an OwnerRequirement on the attach modifier. -->
	<Modifier id="BOSE_MOD_SPRINGING_TIGER_ATTACH" collection="COLLECTION_PLAYER_UNITS" effect="EFFECT_ATTACH_MODIFIERS">
		<OwnerRequirements>
			<Requirement type="REQUIREMENT_PLAYER_HAS_X_WARS">
				<Argument name="WarType">FORMAL_WAR</Argument>
				<Argument name="Amount">1</Argument>
			</Requirement>
		</OwnerRequirements>
		<Argument name="ModifierId">BOSE_MOD_SPRINGING_TIGER_COMBAT</Argument>
	</Modifier>
	<Modifier id="BOSE_MOD_SPRINGING_TIGER_COMBAT" collection="COLLECTION_UNIT_COMBAT" effect="EFFECT_ADJUST_UNIT_STRENGTH_MODIFIER">
		<Argument name="Amount">1</Argument>
		<String context="Preview">LOC_ABILITY_BOSE_SPRINGING_TIGER_PREVIEW</String>
	</Modifier>

	<!-- 5. +1 Influence per turn, increasing each Age (Bose's Azad Hind Radio
	        broadcasts). Refolded from the former Azad Hind Radio memento; copied
	        from the Machiavelli/Toyotomi influence pattern (COLLECTION_OWNER +
	        EFFECT_PLAYER_ADJUST_YIELD + YIELD_DIPLOMACY + ScaleByGameAge). -->
	<Modifier id="BOSE_MOD_AZAD_HIND_RADIO_INFLUENCE" collection="COLLECTION_OWNER" effect="EFFECT_PLAYER_ADJUST_YIELD">
		<Argument name="YieldType">YIELD_DIPLOMACY</Argument>
		<Argument name="Amount" type="ScaleByGameAge" extra="100">1</Argument>
		<Argument name="Tooltip">LOC_TRAIT_LEADER_BOSE_ABILITY_NAME</Argument>
	</Modifier>

	<!-- Agenda: Purna Swaraj. Relations worsen with players holding many
	     conquered settlements, improve with those holding fewest. Structure +
	     WeightType copied verbatim from the Alexander DLC's
	     ALEXANDER_MOD_AGENDA_GODLIKE_BASILEUS (file: DLC/alexander/modules/
	     data/leaders-gameeffects.xml). AwardAmtType2 uses NEG/SMALL to match
	     that example exactly (previously this mod used the ideology-scoped
	     COMPARE_IDEOLOGY_CAPTURED_SETTLEMENTS WeightType, which is inert
	     before the Modern Age since it depends on an ideology system that
	     doesn't exist yet).
	     REGISTRATION CHECK (see CRITICAL SUB-STEP in task brief): grepped the
	     entire local game install (base-standard + every DLC) for
	     DIPLOMACY_AGENDA_COMPARE_NUM_CONQUERED_SETTLEMENTS. It appears ONLY
	     as an <Argument name="WeightType"> value inside Alexander's own
	     leaders-gameeffects.xml — there is no <Row Type="..."
	     Kind="KIND_DIPLOMACY_AGENDA_WEIGHTING_TYPE"/> for it in
	     base-standard/data/diplomacy-actions.xml (unlike every other
	     DIPLOMACY_AGENDA_COMPARE_* value, which DOES have such a row there,
	     e.g. DIPLOMACY_AGENDA_COMPARE_IDEOLOGY_CAPTURED_SETTLEMENTS at line
	     271 of that file), and no DiplomacyAgendaWeightingTypes row for it
	     either (base-standard has one for every other COMPARE_* at lines
	     1033-1063, but none for NUM_CONQUERED_SETTLEMENTS). Alexander's own
	     config.xml/data files register no such row either. Conclusion: this
	     WeightType is engine-hardcoded (recognized natively by the C++ agenda
	     system without a corresponding data-table entry) rather than
	     data-driven like the rest of the enum. No InsertOrIgnore row is
	     added here because inventing one would risk a bogus duplicate/typed
	     row with no real schema backing — there is nothing to mirror. -->
	<Modifier id="BOSE_MOD_AGENDA_PURNA_SWARAJ" collection="COLLECTION_OWNER" effect="EFFECT_DIPLOMACY_AGENDA_TIMED_UPDATE">
		<String context="Name">LOC_DIPLOMACY_AGENDA_PURNA_SWARAJ_NAME</String>
		<Argument name="ModName">LOC_DIPLOMACY_AGENDA_PURNA_SWARAJ_NAME</Argument>
		<Argument name="Tooltip">LOC_DIPLOMACY_AGENDA_PURNA_SWARAJ_DESC</Argument>
		<Argument name="WeightType">DIPLOMACY_AGENDA_COMPARE_NUM_CONQUERED_SETTLEMENTS</Argument>
		<Argument name="FirstMeetDelay">20</Argument>
		<Argument name="UpdateFreq">10</Argument>
		<Argument name="AwardTo1">DIPLOMACY_AGENDA_AWARD_HIGHEST</Argument>
		<Argument name="AwardAmtType1">DIPLOMACY_AGENDA_NEG_AMT_MEDIUM</Argument>
		<Argument name="AwardTo2">DIPLOMACY_AGENDA_AWARD_LOWEST</Argument>
		<Argument name="AwardAmtType2">DIPLOMACY_AGENDA_AMT_SMALL</Argument>
		<Argument name="NotifyMessage">LOC_NOTIFICATION_DIPLOMATIC_AGENDA_DEFAULT_MESSAGE</Argument>
		<Argument name="NotifySummary">LOC_NOTIFICATION_DIPLOMATIC_AGENDA_DEFAULT_SUMMARY</Argument>
	</Modifier>

</GameEffects>
