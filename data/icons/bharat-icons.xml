<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!-- Icon definitions for the Netaji/Bharat mod. Maps game IDs to art paths.
     Loaded via <UpdateIcons> in netaji-bose.modinfo.

     Paths use fs://game/<name>.PNG (raw PNG the mod ships + <ImportFiles>),
     WITH the .png extension. This matches the confirmed-working pattern from a
     shipped Workshop UI mod (F1rstDan's Cool UI: ImportFiles textures/x.png +
     icon-def Path fs://game/x.png). Our first attempt omitted the extension —
     the log showed it resolving to "/civ_sym_bharat" and failing; adding .png
     is the fix.

     A PNG only resolves if it's also <ImportFiles>-imported in the modinfo.
     Currently only civ_sym_bharat.png exists + is imported (the feasibility
     test). The leader/unit/other-building rows reference PNGs that don't exist
     yet — they fall back harmlessly until the art + their ImportFiles land. -->
<Database>
	<IconDefinitions>
		<!-- Bharat civ symbol (feasibility test — this one is imported + exists). -->
		<Row><ID>CIVILIZATION_BHARAT</ID><Path>fs://game/civ_sym_bharat.png</Path></Row>

		<!-- Civic-tree node icon. Every base civ's unique culture tree sets a
		     per-civ IconString on its nodes (cult_mughal, cult_prussia, ...);
		     TREE_CIVICS_MO_BHARAT's 5 nodes use cult_bharat. Placeholder PNG
		     (a copy of the civ symbol) until real art lands. Imported in the
		     game scope (the culture tree is in-game). -->
		<Row><ID>cult_bharat</ID><Path>fs://game/cult_bharat.png</Path></Row>

		<!-- Building / quarter icons (art pending). -->
		<Row><ID>BUILDING_YOJANA_BHAVAN</ID><Path>fs://game/buildicon_yojana_bhavan.png</Path></Row>
		<Row><ID>BUILDING_VAIDYASHALA</ID><Path>fs://game/buildicon_vaidyashala.png</Path></Row>
		<Row><ID>QUARTER_NATIONAL_PLANNING_COMMISSION</ID><Path>fs://game/buildicon_national_planning_commission.png</Path></Row>

		<!-- Leader portrait (art pending). Hex + circle, a couple of sizes. -->
		<Row><ID>LEADER_SUBHAS_CHANDRA_BOSE</ID><Path>fs://game/lp_hex_bose_256.png</Path><IconSize>256</IconSize></Row>
		<Row><ID>LEADER_SUBHAS_CHANDRA_BOSE</ID><Path>fs://game/lp_hex_bose_128.png</Path><IconSize>128</IconSize></Row>
		<Row><ID>LEADER_SUBHAS_CHANDRA_BOSE</ID><Path>fs://game/lp_circ_bose_256.png</Path><Context>CIRCLE_MASK</Context><IconSize>256</IconSize></Row>
		<Row><ID>LEADER_SUBHAS_CHANDRA_BOSE</ID><Path>fs://game/lp_circ_bose_140.png</Path><Context>PORTRAIT_MASK</Context><IconSize>140</IconSize></Row>

		<!-- Azad Hind Fauj unit flag (art pending). All 3 tiers share one flag. -->
		<Row><ID>UNIT_AZAD_HIND_FAUJ</ID><Path>fs://game/unitflag_azad_hind_fauj.png</Path></Row>
		<Row><ID>UNIT_AZAD_HIND_FAUJ_2</ID><Path>fs://game/unitflag_azad_hind_fauj.png</Path></Row>
		<Row><ID>UNIT_AZAD_HIND_FAUJ_3</ID><Path>fs://game/unitflag_azad_hind_fauj.png</Path></Row>
		<!-- Wave-2 unit flags (art pending — rows fall back harmlessly). -->
		<Row><ID>UNIT_RANI_OF_JHANSI_REGIMENT</ID><Path>fs://game/unitflag_rani_of_jhansi.png</Path></Row>
		<Row><ID>UNIT_AZAD_HIND_NAU_SENA</ID><Path>fs://game/unitflag_nau_sena.png</Path></Row>
		<Row><ID>UNIT_BAHADUR_GROUP</ID><Path>fs://game/unitflag_bahadur.png</Path></Row>
	</IconDefinitions>
</Database>
