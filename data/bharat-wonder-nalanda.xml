<?xml version="1.0" encoding="utf-8"?>
<!-- HERITAGE OVERHAUL layer 3 — EXPERIMENT: Wonder "Nalanda" (Exploration
     age). Nalanda mahavihara (founded ~5th c. CE; described by Xuanzang and
     Yijing) — Tier-A history: a residential centre of learning with entrance
     examination, libraries, and a multi-disciplinary curriculum.

     Data shape mirrors the official add-on wonder template verbatim
     (DLC/asia-wonders/modules/data/constructibles-exploration.xml,
     WONDER_WAT_XIENG_THONG; base twin: WONDER_BRIHADEESWARAR_TEMPLE at
     age-exploration/data/constructibles.xml:137). No KIND_WONDER exists —
     wonders are KIND_CONSTRUCTIBLE + ConstructibleClass="WONDER" + a Wonders
     row.

     THE EXPERIMENT: mods cannot cook 3D wonder art; the only path is
     <UpdateVisualRemaps> borrowing an existing model (data/
     bharat-visual-remaps.xml maps this wonder onto WONDER_BRIHADEESWARAR_
     TEMPLE's model). Remaps are proven for UNIT/BUILDING kinds; a wonder-
     class constructible under Kind=BUILDING is UNTESTED — that is exactly
     what this file exists to find out. If the load or render fails, remove
     the two exploration ActionGroups from the modinfo and everything else in
     the mod is untouched.

     Loaded via criteria="exploration-age-persist" (any of EX/MO) because the
     wonder is AGELESS — a built Nalanda must still exist in Modern-age
     databases. The unlock row loads via exploration-age-current (Firaxis's
     own split in asia-wonders.modinfo).

     One GREATWORKSLOT_ANY great-work slot (base modern wonders' pattern) —
     synergizes with the heritage Great Works: house the Aryabhatiya at
     Nalanda. -->
<Database>
	<Types>
		<Row Type="WONDER_NALANDA" Kind="KIND_CONSTRUCTIBLE"/>
	</Types>
	<TypeQuotes>
		<Row Type="WONDER_NALANDA" Quote="LOC_QUOTE_WONDER_NALANDA" QuoteAuthor="LOC_QUOTE_AUTHOR_WONDER_NALANDA"/>
	</TypeQuotes>
	<Constructibles>
		<Row ConstructibleType="WONDER_NALANDA" Name="LOC_WONDER_NALANDA_NAME" Description="LOC_WONDER_NALANDA_DESCRIPTION" Tooltip="LOC_WONDER_NALANDA_TOOLTIP" ConstructibleClass="WONDER" Cost="550" Population="0" ImmuneDamage="true" Age="AGE_EXPLORATION" RequiresUnlock="true"/>
	</Constructibles>
	<Wonders>
		<Row ConstructibleType="WONDER_NALANDA" MaxWorldInstances="1"/>
	</Wonders>
	<TypeTags>
		<Row Type="WONDER_NALANDA" Tag="AGELESS"/>
	</TypeTags>
	<Constructible_ValidDistricts>
		<Row ConstructibleType="WONDER_NALANDA" DistrictType="DISTRICT_WONDER"/>
	</Constructible_ValidDistricts>
	<Constructible_YieldChanges>
		<Row ConstructibleType="WONDER_NALANDA" YieldType="YIELD_SCIENCE" YieldChange="3"/>
		<Row ConstructibleType="WONDER_NALANDA" YieldType="YIELD_CULTURE" YieldChange="2"/>
	</Constructible_YieldChanges>
	<Constructible_GreatWorks>
		<Row ConstructibleType="WONDER_NALANDA" GreatWorkSlotType="GREATWORKSLOT_ANY" NumSlots="1"/>
	</Constructible_GreatWorks>
	<Constructible_Advisories>
		<Row ConstructibleType="WONDER_NALANDA" AdvisoryClassType="ADVISORY_CLASS_SCIENCE"/>
	</Constructible_Advisories>
</Database>
