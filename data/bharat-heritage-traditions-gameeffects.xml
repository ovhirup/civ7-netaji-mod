<?xml version="1.0" encoding="utf-8"?>
<!-- Modifier definitions for the heritage Traditions + the tradition-slot
     grant (data/bharat-heritage-traditions.xml). Yield modifiers mirror the
     proven shape in data/bharat-traditions-gameeffects.xml (EFFECT_CITY_
     ADJUST_YIELD + COLLECTION_PLAYER_CITIES + Tooltip + Description). The
     slot grant mirrors MOD_PLANES_POLITICOS_TRADITION_SLOT verbatim
     (age-modern/data/progression-trees-culture-unique-gameeffects.xml).
     Distinct yields per tradition — Gold / Science / Culture — so nothing
     double-stacks a single trigger. -->
<GameEffects xmlns="GameEffects">
	<!-- Kautilya's political economy: the treasury as the root of the state. -->
	<Modifier id="ARTHASHASTRA_MOD_GOLD" collection="COLLECTION_PLAYER_CITIES" effect="EFFECT_CITY_ADJUST_YIELD">
		<Argument name="YieldType">YIELD_GOLD</Argument>
		<Argument name="Amount">2</Argument>
		<Argument name="Tooltip">LOC_TRADITION_BHARAT_ARTHASHASTRA_NAME</Argument>
		<String context="Description">LOC_TRADITION_BHARAT_ARTHASHASTRA_DESCRIPTION</String>
	</Modifier>
	<!-- Zero and the decimal place-value system (Aryabhata, Brahmagupta). -->
	<Modifier id="GANITA_MOD_SCIENCE" collection="COLLECTION_PLAYER_CITIES" effect="EFFECT_CITY_ADJUST_YIELD">
		<Argument name="YieldType">YIELD_SCIENCE</Argument>
		<Argument name="Amount">2</Argument>
		<Argument name="Tooltip">LOC_TRADITION_BHARAT_GANITA_NAME</Argument>
		<String context="Description">LOC_TRADITION_BHARAT_GANITA_DESCRIPTION</String>
	</Modifier>
	<!-- Panini's Ashtadhyayi: the formal grammar of Sanskrit. -->
	<Modifier id="ASHTADHYAYI_MOD_CULTURE" collection="COLLECTION_PLAYER_CITIES" effect="EFFECT_CITY_ADJUST_YIELD">
		<Argument name="YieldType">YIELD_CULTURE</Argument>
		<Argument name="Amount">2</Argument>
		<Argument name="Tooltip">LOC_TRADITION_BHARAT_ASHTADHYAYI_NAME</Argument>
		<String context="Description">LOC_TRADITION_BHARAT_ASHTADHYAYI_DESCRIPTION</String>
	</Modifier>
	<!-- +1 tradition slot on the capstone civic (Mexico pattern, verbatim). -->
	<Modifier id="BHARAT_MOD_HERITAGE_TRADITION_SLOT" collection="COLLECTION_OWNER" effect="EFFECT_PLAYER_GRANT_TRADITION_SLOTS" permanent="true">
		<Argument name="SlotType">TRADITION_CULTURE_SLOT</Argument>
		<Argument name="Amount">1</Argument>
		<String context="Description">LOC_BHARAT_MOD_HERITAGE_TRADITION_SLOT_DESCRIPTION</String>
	</Modifier>
</GameEffects>
