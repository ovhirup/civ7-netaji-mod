<?xml version="1.0" encoding="utf-8"?>
<!-- Shell-side (game setup screen) registration.
     Schema copied from ashoka-himiko-alt DLC config/config.xml.
     LeaderIcon: no custom icon ships yet, so the setup screen will show a
     missing/fallback icon until assets land (see assets/README.md). -->
<Database>
	<Leaders>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" LeaderName="LOC_LEADER_SUBHAS_CHANDRA_BOSE_NAME" LeaderDescription="LOC_LEADER_SUBHAS_CHANDRA_BOSE_DESCRIPTION" LeaderIcon="LEADER_SUBHAS_CHANDRA_BOSE" LeaderIntroText="LOC_LOADING_LEADER_INTRO_TEXT_BOSE"/>
	</Leaders>
	<LeaderItems>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Type="TRAIT_LEADER_BOSE_ABILITY" Kind="KIND_TRAIT" Name="LOC_TRAIT_LEADER_BOSE_ABILITY_NAME" Description="LOC_TRAIT_LEADER_BOSE_ABILITY_DESCRIPTION"/>
	</LeaderItems>
	<LeaderTags>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" TagType="TAG_TRAIT_MILITARISTIC"/>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" TagType="TAG_TRAIT_POLITICAL"/>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" TagType="TAG_GENDER_MALE"/>
	</LeaderTags>
	<LeaderQuotes>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Quote="LOC_MAIN_CHAR_SELECT_LEADER_SUBHAS_CHANDRA_BOSE_ANY"/>
	</LeaderQuotes>
	<!-- Setup-screen pairing highlights: the India independence arc across the
	     three ages, all as Historical choices — Maurya -> Chola -> Bharat.
	     Mughal is deliberately NOT listed for Bose: he fought to end imperial
	     rule, so the Mughal Empire is off-theme as a recommendation for him.
	     (Mughal still exists as a normal Modern-age civ in the full list; it's
	     just not surfaced as his highlighted/suggested pick.) -->
	<LeaderCivilizationBias>
		<Row CivilizationDomain="AntiquityAgeCivilizations" CivilizationType="CIVILIZATION_MAURYA" LeaderDomain="StandardLeaders" LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Bias="4" ReasonType="LOC_UNLOCK_PLAY_AS_BOSE_MAURYA_TOOLTIP" ChoiceType="LOC_CREATE_GAME_HISTORICAL_CHOICE"/>
		<Row CivilizationDomain="ExplorationAgeCivilizations" CivilizationType="CIVILIZATION_CHOLA" LeaderDomain="StandardLeaders" LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Bias="4" ReasonType="LOC_UNLOCK_PLAY_AS_BOSE_CHOLA_TOOLTIP" ChoiceType="LOC_CREATE_GAME_HISTORICAL_CHOICE"/>
		<Row CivilizationDomain="ModernAgeCivilizations" CivilizationType="CIVILIZATION_BHARAT" LeaderDomain="StandardLeaders" LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Bias="4" ReasonType="LOC_UNLOCK_PLAY_AS_BOSE_BHARAT_TOOLTIP" ChoiceType="LOC_CREATE_GAME_HISTORICAL_CHOICE"/>
	</LeaderCivilizationBias>
	<!-- Mementos were dropped (custom mementos can't be made equippable without
	     fragile core-UI-file replacement); their effects are refolded into the
	     leader ability. See data/leaders-gameeffects.xml and DESIGN.md. -->
</Database>
