<?xml version="1.0" encoding="utf-8"?>
<!-- Shell-side (game setup screen) registration.
     Schema copied from ashoka-himiko-alt DLC config/config.xml.
     LeaderIcon: no custom icon ships yet, so the setup screen will show a
     missing/fallback icon until assets land (see assets/README.md). -->
<Database>
	<Leaders>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" LeaderName="LOC_LEADER_SUBHAS_CHANDRA_BOSE_NAME" LeaderDescription="LOC_LEADER_SUBHAS_CHANDRA_BOSE_DESCRIPTION" LeaderIcon="LEADER_SUBHAS_CHANDRA_BOSE" LeaderIntroText="LOC_LOADING_LEADER_INTRO_TEXT_BOSE"/>
	</Leaders>
	<LeaderItems>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Type="TRAIT_LEADER_BOSE_ABILITY" Kind="KIND_TRAIT" Name="LOC_TRAIT_LEADER_BOSE_ABILITY_NAME" Description="LOC_TRAIT_LEADER_BOSE_ABILITY_DESCRIPTION"/>
	</LeaderItems>
	<LeaderTags>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" TagType="TAG_TRAIT_MILITARISTIC"/>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" TagType="TAG_TRAIT_POLITICAL"/>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" TagType="TAG_GENDER_MALE"/>
	</LeaderTags>
	<LeaderQuotes>
		<Row LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Quote="LOC_MAIN_CHAR_SELECT_LEADER_SUBHAS_CHANDRA_BOSE_ANY"/>
	</LeaderQuotes>
	<!-- Setup-screen pairing highlights: the India arc across the three ages -->
	<LeaderCivilizationBias>
		<Row CivilizationDomain="AntiquityAgeCivilizations" CivilizationType="CIVILIZATION_MAURYA" LeaderDomain="StandardLeaders" LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Bias="4" ReasonType="LOC_UNLOCK_PLAY_AS_BOSE_MAURYA_TOOLTIP" ChoiceType="LOC_CREATE_GAME_HISTORICAL_CHOICE"/>
		<Row CivilizationDomain="ExplorationAgeCivilizations" CivilizationType="CIVILIZATION_CHOLA" LeaderDomain="StandardLeaders" LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Bias="4" ReasonType="LOC_UNLOCK_PLAY_AS_BOSE_CHOLA_TOOLTIP" ChoiceType="LOC_CREATE_GAME_HISTORICAL_CHOICE"/>
		<Row CivilizationDomain="ModernAgeCivilizations" CivilizationType="CIVILIZATION_MUGHAL" LeaderDomain="StandardLeaders" LeaderType="LEADER_SUBHAS_CHANDRA_BOSE" Bias="4" ReasonType="LOC_UNLOCK_PLAY_AS_BOSE_MUGHAL_TOOLTIP" ChoiceType="LOC_CREATE_GAME_HISTORICAL_CHOICE"/>
	</LeaderCivilizationBias>
	<!-- Mementos Data. Row placement/columns copied verbatim from
	     ashoka-himiko-alt DLC's config/config.xml <Mementos> block.
	     Hidden="0" (schema default is 1/hidden) is INTENDED to make both
	     mementos available immediately with no metaprogression grind, but
	     this is UNVERIFIED: no official row sets Hidden="0", and the shell
	     memento picker also consults Online.Metaprogression /
	     Online.UserProfile.isRewardUnlocked (see core/ui/shell/create-panels/
	     memento-editor.js). First in-game check: confirm both tiles are
	     SELECTABLE, not merely visible. If locked, availability needs a
	     different path (e.g. unlockableRewards/LegendPathsRewards rows). -->
	<Mementos>
		<Row Type="MEMENTO_BOSE_SPRINGING_TIGER" Name="LOC_MEMENTO_BOSE_SPRINGING_TIGER_NAME" Description="LOC_MEMENTO_BOSE_SPRINGING_TIGER_DESCRIPTION" FunctionalDescription="LOC_MEMENTO_BOSE_SPRINGING_TIGER_FUNCTIONAL_DESCRIPTION" UnlockTitle="LOC_MEMENTO_BOSE_SPRINGING_TIGER_UNLOCK_TITLE" Tag="LOC_ATTRIBUTE_MILITARISTIC" Hidden="0"/>
		<Row Type="MEMENTO_BOSE_AZAD_HIND_RADIO" Name="LOC_MEMENTO_BOSE_AZAD_HIND_RADIO_NAME" Description="LOC_MEMENTO_BOSE_AZAD_HIND_RADIO_DESCRIPTION" FunctionalDescription="LOC_MEMENTO_BOSE_AZAD_HIND_RADIO_FUNCTIONAL_DESCRIPTION" UnlockTitle="LOC_MEMENTO_BOSE_AZAD_HIND_RADIO_UNLOCK_TITLE" Tag="LOC_ATTRIBUTE_DIPLOMATIC" Hidden="0"/>
	</Mementos>
</Database>
