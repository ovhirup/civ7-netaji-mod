		<Row ProgressionTreeNodeType="NODE_CIVIC_MO_BHARAT_NATIONAL_PLANNING" ProgressionTree="TREE_CIVICS_MO_BHARAT" Cost="4000" Name="LOC_CIVIC_BHARAT_NATIONAL_PLANNING_NAME" IconString="cult_bharat"/>
