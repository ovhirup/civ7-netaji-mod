<?xml version="1.0" encoding="utf-8"?>
<!-- FRONTEND copy of Bharat's civic-tree + traditions, for the game-SETUP
     screens (Civilization Details "Traditions" page). The ui-next civ-details
     page queries the CONFIG database (DatabaseCache("config") in
     core/ui-next/screens/create-game/civ-select-model.js:10, joining
     Traditions x ProgressionTreeNodeUnlocks x ProgressionTreeNodes by the
     civ's TraitType) — gameplay-side data is invisible there. Every base civ
     ships this frontend copy via config (template:
     age-modern/config/civics-traditions.xml, loaded in the age-modern-shell
     ActionGroup); this mirrors our data/bharat-traditions.xml +
     data/bharat-progression-trees.xml rows in the frontend shape (3 tables
     only — no Types/ProgressionTrees rows needed frontend-side). -->
<Database>
	<Traditions>
		<Row TraditionType="TRADITION_BHARAT_SWADESHI" Name="LOC_TRADITION_BHARAT_SWADESHI_NAME" Description="LOC_TRADITION_BHARAT_SWADESHI_DESCRIPTION" TraitType="TRAIT_BHARAT" AgeType="AGE_MODERN" CultureSlotType="TRADITION_CULTURE_SLOT"/>
		<Row TraditionType="TRADITION_BHARAT_PURNA_SWARAJ" Name="LOC_TRADITION_BHARAT_PURNA_SWARAJ_NAME" Description="LOC_TRADITION_BHARAT_PURNA_SWARAJ_DESCRIPTION" TraitType="TRAIT_BHARAT" AgeType="AGE_MODERN" CultureSlotType="TRADITION_CULTURE_SLOT"/>
		<Row TraditionType="TRADITION_BHARAT_FORWARD_BLOC" Name="LOC_TRADITION_BHARAT_FORWARD_BLOC_NAME" Description="LOC_TRADITION_BHARAT_FORWARD_BLOC_DESCRIPTION" TraitType="TRAIT_BHARAT" AgeType="AGE_MODERN" CultureSlotType="TRADITION_CULTURE_SLOT"/>
		<Row TraditionType="TRADITION_BHARAT_AZAD_HIND" Name="LOC_TRADITION_BHARAT_AZAD_HIND_NAME" Description="LOC_TRADITION_BHARAT_AZAD_HIND_DESCRIPTION" TraitType="TRAIT_BHARAT" AgeType="AGE_MODERN" CultureSlotType="TRADITION_CULTURE_SLOT"/>
		<Row TraditionType="TRADITION_BHARAT_NATIONAL_PLANNING" Name="LOC_TRADITION_BHARAT_NATIONAL_PLANNING_NAME" Description="LOC_TRADITION_BHARAT_NATIONAL_PLANNING_DESCRIPTION" TraitType="TRAIT_BHARAT" AgeType="AGE_MODERN" CultureSlotType="TRADITION_CULTURE_SLOT"/>
	</Traditions>
	<ProgressionTreeNodes>
		<Row ProgressionTreeNodeType="NODE_CIVIC_MO_BHARAT_SWADESHI" ProgressionTree="TREE_CIVICS_MO_BHARAT" Cost="2000" Name="LOC_CIVIC_BHARAT_SWADESHI_NAME" IconString="cult_bharat"/>
		<Row ProgressionTreeNodeType="NODE_CIVIC_MO_BHARAT_PURNA_SWARAJ" ProgressionTree="TREE_CIVICS_MO_BHARAT" Cost="2000" Name="LOC_CIVIC_BHARAT_PURNA_SWARAJ_NAME" IconString="cult_bharat"/>
